 162:../../base/./simpleserial/simpleserial.c **** void simpleserial_get(void)
 163:../../base/./simpleserial/simpleserial.c **** {
 164:../../base/./simpleserial/simpleserial.c **** 	uint8_t data_buf[MAX_SS_LEN];
 165:../../base/./simpleserial/simpleserial.c **** 	uint8_t err = 0;
 166:../../base/./simpleserial/simpleserial.c **** 
 167:../../base/./simpleserial/simpleserial.c **** 	for (int i = 0; i < 4; i++) {
 168:../../base/./simpleserial/simpleserial.c **** 		data_buf[i] = getch(); //PTR, cmd, scmd, len
 169:../../base/./simpleserial/simpleserial.c **** 		if (data_buf[i] == FRAME_BYTE) {
 170:../../base/./simpleserial/simpleserial.c **** 			err = SS_ERR_FRAME_BYTE;
 171:../../base/./simpleserial/simpleserial.c **** 			goto ERROR;
 172:../../base/./simpleserial/simpleserial.c **** 		}
 173:../../base/./simpleserial/simpleserial.c **** 	}
 174:../../base/./simpleserial/simpleserial.c **** 	uint8_t next_frame = unstuff_data(data_buf, 4);
 175:../../base/./simpleserial/simpleserial.c **** 
 176:../../base/./simpleserial/simpleserial.c **** 	// check for valid command
 177:../../base/./simpleserial/simpleserial.c **** 	uint8_t c = 0;
 178:../../base/./simpleserial/simpleserial.c **** 	for(c = 0; c < num_commands; c++)
 179:../../base/./simpleserial/simpleserial.c **** 	{
 180:../../base/./simpleserial/simpleserial.c **** 		if(commands[c].c == data_buf[1])
 181:../../base/./simpleserial/simpleserial.c **** 			break;
 182:../../base/./simpleserial/simpleserial.c **** 	}
 183:../../base/./simpleserial/simpleserial.c **** 
 184:../../base/./simpleserial/simpleserial.c **** 	if (c == num_commands) {
 185:../../base/./simpleserial/simpleserial.c **** 		err = SS_ERR_CMD;
 186:../../base/./simpleserial/simpleserial.c **** 		goto ERROR;
 187:../../base/./simpleserial/simpleserial.c **** 	}
 188:../../base/./simpleserial/simpleserial.c **** 
 189:../../base/./simpleserial/simpleserial.c **** 	//check that next frame not beyond end of message
 190:../../base/./simpleserial/simpleserial.c **** 	// account for cmd, scmd, len, data, crc, end of frame
 191:../../base/./simpleserial/simpleserial.c **** 	if ((data_buf[3] + 5) < next_frame) {
 192:../../base/./simpleserial/simpleserial.c **** 		err = SS_ERR_LEN;
 193:../../base/./simpleserial/simpleserial.c **** 		goto ERROR;
 194:../../base/./simpleserial/simpleserial.c **** 	}
 195:../../base/./simpleserial/simpleserial.c **** 
 196:../../base/./simpleserial/simpleserial.c **** 	// read in data
 197:../../base/./simpleserial/simpleserial.c **** 	// eq to len + crc + frame end
 198:../../base/./simpleserial/simpleserial.c **** 	int i = 4;
 199:../../base/./simpleserial/simpleserial.c **** 	for (; i < data_buf[3] + 5; i++) {
 200:../../base/./simpleserial/simpleserial.c **** 		data_buf[i] = getch();
 201:../../base/./simpleserial/simpleserial.c **** 		if (data_buf[i] == FRAME_BYTE) {
 202:../../base/./simpleserial/simpleserial.c **** 			err = SS_ERR_FRAME_BYTE;
 203:../../base/./simpleserial/simpleserial.c **** 			goto ERROR;
 204:../../base/./simpleserial/simpleserial.c **** 		}
 205:../../base/./simpleserial/simpleserial.c **** 	}
 206:../../base/./simpleserial/simpleserial.c **** 
 207:../../base/./simpleserial/simpleserial.c **** 	//check that final byte is the FRAME_BYTE
 208:../../base/./simpleserial/simpleserial.c **** 	data_buf[i] = getch();
 209:../../base/./simpleserial/simpleserial.c **** 	if (data_buf[i] != FRAME_BYTE) {
 210:../../base/./simpleserial/simpleserial.c **** 		err = SS_ERR_LEN;
 211:../../base/./simpleserial/simpleserial.c **** 		goto ERROR;
 212:../../base/./simpleserial/simpleserial.c **** 	}
 213:../../base/./simpleserial/simpleserial.c **** 
 214:../../base/./simpleserial/simpleserial.c **** 	//fully unstuff data now
 215:../../base/./simpleserial/simpleserial.c **** 	unstuff_data(data_buf + next_frame, i - next_frame + 1);
 216:../../base/./simpleserial/simpleserial.c **** 
 217:../../base/./simpleserial/simpleserial.c **** 	//calc crc excluding original frame offset and frame end and crc
 218:../../base/./simpleserial/simpleserial.c **** 	uint8_t crc = ss_crc(data_buf+1, i-2);
 219:../../base/./simpleserial/simpleserial.c **** 	if (crc != data_buf[i-1]) {
 220:../../base/./simpleserial/simpleserial.c **** 		err = SS_ERR_CRC;
 221:../../base/./simpleserial/simpleserial.c **** 		goto ERROR;
 222:../../base/./simpleserial/simpleserial.c **** 	}
 223:../../base/./simpleserial/simpleserial.c **** 
 224:../../base/./simpleserial/simpleserial.c **** 	err = commands[c].fp(data_buf[1], data_buf[2], data_buf[3], data_buf+4);
 225:../../base/./simpleserial/simpleserial.c **** 
 226:../../base/./simpleserial/simpleserial.c **** ERROR:
 227:../../base/./simpleserial/simpleserial.c **** 	simpleserial_put('e', 0x01, &err);
 228:../../base/./simpleserial/simpleserial.c **** 	return;
 229:../../base/./simpleserial/simpleserial.c **** }
